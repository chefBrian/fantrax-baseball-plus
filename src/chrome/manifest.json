{
  "manifest_version": 3,
  "name": "Fantrax+",
  "version": "1.0.0",
  "description": "Adds Baseball Reference, Statcast, and MLB Video links to Fantrax player pages",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://fastball-gateway.mlb.com/*",
    "https://statsapi.mlb.com/*",
    "https://fastball-clips.mlb.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://*.fantrax.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
